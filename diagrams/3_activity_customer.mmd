flowchart TD
    Start((●)) --> A["เข้าสู่ระบบ / สมัครสมาชิก"]
    A --> B["เข้าสู่หน้าแรก (หน้าร้าน)"]
    B --> C["ค้นหาสินค้า\n(กรองตาม แบรนด์ / รุ่น / ประเภท\nช่วงราคา / เพศ / คุณสมบัติ / เรียงลำดับ)"]
    C --> D["แสดงผลหน้ารายการสินค้า"]
    D --> E{"พบสินค้า\nที่ต้องการ?"}
    E -- ไม่ใช่ --> C
    E -- ใช่ --> F["ดูรายละเอียดสินค้า"]
    F --> G{"ต้องการซื้อ?"}
    G -- ไม่ใช่ --> C
    G -- ใช่ --> H["เพิ่มลงตะกร้า"]
    H --> I["ดูตะกร้าสินค้า / แก้ไขจำนวน"]
    I --> J{"ยืนยัน\nคำสั่งซื้อ?"}
    J -- ไม่ใช่ --> B
    J -- ใช่ --> K["กรอกที่อยู่จัดส่ง"]
    K --> L["เลือกการจัดส่ง"]
    L --> M["เลือกวิธีชำระเงิน"]
    M --> N["ชำระเงิน"]
    N --> O["ตรวจสอบการชำระเงิน"]
    O --> P{"สำเร็จ?"}
    P -- สำเร็จ --> Q["ยืนยันคำสั่งซื้อสำเร็จ\n(แสดงเลขที่คำสั่งซื้อ)"]
    Q --> End((◉))
    P -- ไม่สำเร็จ --> R["การชำระเงินล้มเหลว\n(แจ้งเตือน / ให้ลองใหม่)"]
    R --> M
